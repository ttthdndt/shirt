# Copy to .env and fill in real values — never commit this file!

# Grok API (get from console.x.ai)
GROK_API_KEY=xai-your-key-here
GROK_MODEL=grok-2-image-1212

# WordPress
WP_BASE_URL=https://motasport.com
WP_USERNAME=admin
WP_APP_PASS=xxxx xxxx xxxx xxxx xxxx xxxx

# Flask
SECRET_KEY=change-me-to-a-random-string

# Storage folders (VPS — persistent across restarts)
UPLOAD_FOLDER=/var/shirt-pipeline/uploads
OUTPUT_FOLDER=/var/shirt-pipeline/outputs
GARMENT_FOLDER=/var/shirt-pipeline/garments
